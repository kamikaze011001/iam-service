# =============================================================================
# IAM Service — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------
# JDBC connection URL for the PostgreSQL instance
DB_URL=jdbc:postgresql://localhost:5432/iam
# Database user credentials (must match docker-compose.yml)
DB_USERNAME=iam
DB_PASSWORD=iam

# -----------------------------------------------------------------------------
# Redis (cache, sessions, OTP store)
# -----------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379

# -----------------------------------------------------------------------------
# Google OAuth2
# Get credentials from: https://console.cloud.google.com → APIs & Services → Credentials
# Authorized redirect URI must include: http://localhost:8080/login/oauth2/code/google
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# -----------------------------------------------------------------------------
# JWT (RS256 — RSA key pair)
# Generate with:
#   openssl genrsa -out private.pem 2048
#   openssl rsa -in private.pem -pubout -out public.pem
# Paste the full PEM content on a single line with literal \n for newlines.
# -----------------------------------------------------------------------------
JWT_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----
JWT_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----
# Access token lifetime in minutes (default: 15)
JWT_TTL_MINUTES=15

# -----------------------------------------------------------------------------
# WebAuthn / Passkey
# RP_ID must match the domain the browser navigates to (no port, no protocol).
# RP_ORIGIN must match the exact origin (protocol + host + optional port).
# For local development: RP_ID=localhost, RP_ORIGIN=http://localhost:3000
# -----------------------------------------------------------------------------
WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_ORIGIN=http://localhost:3000
WEBAUTHN_RP_NAME=IAM Service

# -----------------------------------------------------------------------------
# Email / SMTP (used for OTP delivery)
# For local development, use Mailpit: https://mailpit.axllent.org
# For production, use a transactional provider (SendGrid, SES, Postmark, etc.)
# -----------------------------------------------------------------------------
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
# SMTP auth credentials (for Gmail: use an App Password, not your account password)
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
# The "From" address shown in sent emails
MAIL_FROM=noreply@yourdomain.com
MAIL_FROM_NAME=IAM Service

# -----------------------------------------------------------------------------
# CORS & Frontend URL
# CORS_ALLOWED_ORIGINS: comma-separated list of allowed browser origins
# FRONTEND_URL: base URL used for redirect links in emails
# -----------------------------------------------------------------------------
CORS_ALLOWED_ORIGINS=http://localhost:3000
FRONTEND_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# OAuth2 Authorization Server clients
# -----------------------------------------------------------------------------
# Redirect URI registered for the iam-web SPA client
IAM_WEB_REDIRECT_URI=http://localhost:3000/callback
# Client secret for the iam-service machine-to-machine client
# Prefix {noop} means the value is stored as plain text (dev only).
# In production, use {bcrypt} with a hashed value.
IAM_SERVICE_CLIENT_SECRET={noop}changeme

# Email of the user to promote to ADMIN on startup (optional; user must already be registered)
BOOTSTRAP_ADMIN_EMAIL=
# -----------------------------------------------------------------------------
# Rate Limiting
# -----------------------------------------------------------------------------
# Set to false to disable rate limiting in local development
RATE_LIMIT_ENABLED=true
# Maximum requests per minute per IP
RATE_LIMIT_RPM=100
# Comma-separated CIDR blocks of trusted reverse-proxy IPs (leave empty if none)
RATE_LIMIT_TRUSTED_PROXIES=

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------
PORT=8080
APP_BASE_URL=http://localhost:8080
